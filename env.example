# --- Public URL (metadata, client hints) ---
# Use your real apex, e.g. https://fighurai.ai
NEXT_PUBLIC_SITE_URL=https://fighurai.ai

# --- OAuth redirect base (must match Google / Azure app registration) ---
# Usually same origin as the site:
SMILE_OAUTH_BASE_URL=https://fighurai.ai

# --- Sealing: sessions + encrypted user connection files (min 16 chars) ---
SMILE_APP_SECRET=replace-with-long-random-string
# If you omit SMILE_APP_SECRET, set instead:
# SMILE_OAUTH_COOKIE_SECRET=replace-with-long-random-string

# --- Auth: disable insecure email-only sign-in (use password + SSO instead) ---
# SMILE_ALLOW_DEMO_EMAIL_AUTH=false

# --- Plans: comma-separated emails auto-receive Pro (all models) ---
# SMILE_PRO_EMAILS=you@example.com

# --- Dev only: POST /api/billing/upgrade sets plan=pro without Stripe ---
# SMILE_ALLOW_DEV_PRO_UPGRADE=false

# --- Per-user data on disk (profiles, encrypted OAuth tokens) ---
# Serverless hosts wipe disk between invocations — use a VPS, Fly volume, Railway volume, etc.,
# and point this to a persistent path. Example:
# SMILE_USER_DATA_DIR=/var/lib/smile-ai/data

# --- Model providers (set at least one — required for chat on fighur.ai) ---
# In Vercel: Project → Settings → Environment Variables → Production → Redeploy
ANTHROPIC_API_KEY=
# SMILE_DEFAULT_CHAT_MODEL=openai:gpt-4o-mini
# OPENAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# NVIDIA_API_KEY=

# --- Google OAuth (SSO sign-in + optional Gmail/Calendar connect) ---
# Register redirect URIs in Google Cloud → Credentials → OAuth client (Web):
#   https://fighur.ai/api/auth/sso/google/callback
#   https://fighur.ai/api/connect/google/callback
# See docs/GOOGLE_SSO_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth (fighur ai app — see docs/CONNECTORS_SETUP.md) ---
# MICROSOFT_CLIENT_ID=4c5436c0-3e68-4c79-af81-8d3a745f6d2c
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Web search (optional — DuckDuckGo instant fallback works without a key) ---
# Brave: https://brave.com/search/api/ (recommended for full results)
# BRAVE_SEARCH_API_KEY=
# Tavily: https://tavily.com/
# TAVILY_API_KEY=

# --- Optional ---
# OPENROUTER_REFERER=https://fighurai.ai
